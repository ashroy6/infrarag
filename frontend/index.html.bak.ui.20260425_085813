<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>InfraRAG</title>
  <style>
    :root {
      --bg: #0f172a;
      --panel: #111827;
      --panel-2: #1f2937;
      --card: #ffffff;
      --muted: #94a3b8;
      --text: #e5e7eb;
      --border: #334155;
      --accent: #2563eb;
      --danger: #dc2626;
      --user: #2563eb;
      --assistant: #111827;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #f8fafc;
      color: #111827;
      height: 100vh;
      overflow: hidden;
    }

    .app {
      display: grid;
      grid-template-columns: 290px 1fr;
      height: 100vh;
    }

    .sidebar {
      background: var(--bg);
      color: var(--text);
      display: flex;
      flex-direction: column;
      border-right: 1px solid #020617;
      min-width: 0;
    }

    .sidebar-header {
      padding: 16px;
      border-bottom: 1px solid var(--border);
    }

    .brand {
      font-size: 21px;
      font-weight: 700;
      margin-bottom: 12px;
    }

    .new-chat-btn,
    .admin-link {
      width: 100%;
      border: 1px solid var(--border);
      background: var(--panel);
      color: var(--text);
      border-radius: 10px;
      padding: 11px 12px;
      cursor: pointer;
      font-size: 15px;
      text-align: left;
      margin-bottom: 8px;
      text-decoration: none;
      display: block;
    }

    .new-chat-btn:hover,
    .admin-link:hover {
      background: var(--panel-2);
    }

    .conversation-list {
      flex: 1;
      overflow-y: auto;
      padding: 10px;
    }

    .conversation-item {
      padding: 10px 10px;
      border-radius: 10px;
      margin-bottom: 6px;
      cursor: pointer;
      color: #d1d5db;
      font-size: 14px;
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 8px;
      align-items: center;
    }

    .conversation-item:hover {
      background: var(--panel);
    }

    .conversation-item.active {
      background: var(--panel-2);
      color: white;
    }

    .conversation-title {
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .delete-chat {
      border: none;
      background: transparent;
      color: #94a3b8;
      cursor: pointer;
      font-size: 15px;
      padding: 2px 4px;
      border-radius: 6px;
    }

    .delete-chat:hover {
      color: white;
      background: var(--danger);
    }

    .main {
      display: grid;
      grid-template-rows: auto 1fr auto;
      height: 100vh;
      min-width: 0;
    }

    .top {
      background: white;
      border-bottom: 1px solid #e5e7eb;
      padding: 14px 20px;
    }

    .top h1 {
      margin: 0;
      font-size: 22px;
    }

    .top p {
      margin: 4px 0 0;
      color: #64748b;
      font-size: 14px;
    }

    .controls {
      background: #f8fafc;
      border-bottom: 1px solid #e5e7eb;
      padding: 12px 20px;
    }

    .row {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-bottom: 10px;
    }

    .row:last-child {
      margin-bottom: 0;
    }

    input[type="text"],
    input[type="number"],
    select {
      padding: 10px 11px;
      border: 1px solid #cbd5e1;
      border-radius: 8px;
      font-size: 14px;
      background: white;
      min-width: 180px;
      flex: 1;
    }

    .small-input {
      max-width: 170px;
    }

    .inline-check {
      display: flex;
      align-items: center;
      gap: 7px;
      color: #475569;
      font-size: 14px;
    }

    .source-summary {
      color: #64748b;
      font-size: 13px;
    }

    .messages {
      overflow-y: auto;
      padding: 24px 20px 140px;
      background: #f8fafc;
    }

    .message {
      max-width: 980px;
      margin: 0 auto 18px;
      display: grid;
      grid-template-columns: 42px 1fr;
      gap: 12px;
    }

    .avatar {
      width: 36px;
      height: 36px;
      border-radius: 999px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-weight: 700;
      font-size: 14px;
    }

    .avatar.user {
      background: var(--user);
    }

    .avatar.assistant {
      background: var(--assistant);
    }

    .bubble {
      background: white;
      border: 1px solid #e5e7eb;
      border-radius: 14px;
      padding: 14px 16px;
      line-height: 1.6;
      white-space: pre-wrap;
      word-break: break-word;
      box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
    }

    .message.user-message .bubble {
      background: #eff6ff;
      border-color: #bfdbfe;
    }

    .meta-box {
      background: #f1f5f9;
      border: 1px solid #dbe4ee;
      border-radius: 10px;
      padding: 9px 10px;
      margin-bottom: 12px;
      font-size: 13px;
      color: #334155;
      white-space: normal;
    }

    .meta-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 6px 12px;
    }

    .citations {
      margin-top: 14px;
      border-top: 1px solid #e5e7eb;
      padding-top: 10px;
      font-size: 13px;
      color: #334155;
      white-space: normal;
    }

    .citation-item {
      padding: 7px 8px;
      border-radius: 8px;
      background: #f8fafc;
      margin-top: 6px;
      border: 1px solid #e2e8f0;
    }

    .composer {
      position: fixed;
      bottom: 0;
      left: 290px;
      right: 0;
      background: linear-gradient(to top, #f8fafc 80%, rgba(248,250,252,0));
      padding: 22px 20px 18px;
    }

    .composer-inner {
      max-width: 980px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 10px;
      background: white;
      border: 1px solid #cbd5e1;
      border-radius: 16px;
      padding: 10px;
      box-shadow: 0 8px 30px rgba(15, 23, 42, 0.08);
    }

    #question {
      border: none;
      outline: none;
      font-size: 16px;
      min-width: 0;
    }

    .ask-btn {
      border: none;
      border-radius: 12px;
      background: #111827;
      color: white;
      padding: 10px 16px;
      cursor: pointer;
      font-size: 15px;
    }

    .ask-btn:hover {
      background: #1f2937;
    }

    .ask-btn:disabled {
      background: #94a3b8;
      cursor: not-allowed;
    }

    .upload-panel {
      padding: 12px 20px;
      border-top: 1px solid #e5e7eb;
      background: white;
      display: none;
    }

    .upload-panel.open {
      display: block;
    }

    .secondary-btn {
      border: 1px solid #cbd5e1;
      background: white;
      color: #111827;
      border-radius: 8px;
      padding: 9px 11px;
      cursor: pointer;
      font-size: 14px;
    }

    .secondary-btn:hover {
      background: #f1f5f9;
    }

    input[type="file"] {
      padding: 8px;
      border: 1px solid #cbd5e1;
      border-radius: 8px;
      background: white;
      font-size: 14px;
      flex: 1;
      min-width: 250px;
    }

    .status {
      color: #475569;
      font-size: 13px;
    }

    .empty-state {
      max-width: 760px;
      margin: 70px auto;
      text-align: center;
      color: #64748b;
    }

    .empty-state h2 {
      color: #111827;
      margin-bottom: 8px;
    }

    @media (max-width: 850px) {
      .app {
        grid-template-columns: 1fr;
      }

      .sidebar {
        display: none;
      }

      .composer {
        left: 0;
      }
    }
  </style>
</head>
<body>
  <div class="app">
    <aside class="sidebar">
      <div class="sidebar-header">
        <div class="brand">InfraRAG</div>
        <button class="new-chat-btn" onclick="newChat()">+ New Chat</button>
        <a class="admin-link" href="/admin.html">Open Admin UI</a>
      </div>
      <div id="conversationList" class="conversation-list">
        Loading chats...
      </div>
    </aside>

    <main class="main">
      <div>
        <div class="top">
          <h1>InfraRAG</h1>
          <p>Private RAG assistant with automatic pipeline routing, citations, and chat history.</p>
        </div>

        <div class="controls">
          <div class="row">
            <input id="sourceSearch" type="text" placeholder="Search sources by name/path (optional)" oninput="renderSourceOptions()" />
            <select id="sourceTypeFilter" onchange="renderSourceOptions()">
              <option value="">All source types</option>
              <option value="upload">Uploads</option>
              <option value="git">Git</option>
              <option value="local">Local</option>
            </select>
            <label class="inline-check">
              <input id="showAllSources" type="checkbox" onchange="renderSourceOptions()" />
              Show all sources
            </label>
            <button class="secondary-btn" onclick="toggleUploadPanel()">Uploads</button>
          </div>

          <div class="row">
            <select id="sourceSelect">
              <option value="">All sources</option>
            </select>
            <input id="pageStart" class="small-input" type="number" min="1" placeholder="Page start" />
            <input id="pageEnd" class="small-input" type="number" min="1" placeholder="Page end" />
          </div>

          <div id="sourceSummary" class="source-summary">Loading sources...</div>
        </div>

        <div id="uploadPanel" class="upload-panel">
          <div class="row">
            <input id="fileInput" type="file" />
            <button class="secondary-btn" onclick="uploadFile()">Upload File</button>
            <span class="status" id="uploadStatus">No single file uploaded yet.</span>
          </div>

          <div class="row">
            <input id="folderInput" type="file" webkitdirectory directory multiple />
            <button class="secondary-btn" onclick="uploadFolder()">Upload Folder</button>
            <span class="status" id="folderStatus">No folder uploaded yet.</span>
          </div>
        </div>
      </div>

      <section id="messages" class="messages">
        <div class="empty-state">
          <h2>Start a new InfraRAG chat</h2>
          <p>Ask about uploaded books, DevOps docs, Terraform repos, incidents, or summaries. The backend decides the best pipeline automatically.</p>
        </div>
      </section>

      <div class="composer">
        <div class="composer-inner">
          <input id="question" type="text" placeholder="Ask a question..." onkeydown="handleQuestionKey(event)" />
          <button id="askButton" class="ask-btn" onclick="askQuestion()">Ask</button>
        </div>
      </div>
    </main>
  </div>

  <script>
    const RECENT_SOURCE_LIMIT = 20;

    let allSources = [];
    let conversations = [];
    let currentConversationId = null;
    let messages = [];
    let isAsking = false;

    function escapeHtml(value) {
      return String(value ?? "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#039;");
    }

    async function parseApiResponse(res) {
      const contentType = (res.headers.get("content-type") || "").toLowerCase();
      const rawText = await res.text();

      let data = null;
      if (contentType.includes("application/json")) {
        try {
          data = rawText ? JSON.parse(rawText) : {};
        } catch {
          throw new Error(`API returned invalid JSON. HTTP ${res.status}. Body: ${rawText.slice(0, 300)}`);
        }
      }

      if (!res.ok) {
        if (data && data.error) {
          const message = typeof data.error === "string"
            ? data.error
            : data.error.message || JSON.stringify(data.error);
          throw new Error(`HTTP ${res.status}: ${message}`);
        }

        if (contentType.includes("text/html")) {
          throw new Error(`HTTP ${res.status}: proxy/backend returned HTML instead of JSON`);
        }

        throw new Error(`HTTP ${res.status}: ${rawText.slice(0, 300) || "Unknown error"}`);
      }

      if (!contentType.includes("application/json")) {
        throw new Error(`Expected JSON but got content-type: ${contentType || "unknown"}`);
      }

      return data;
    }

    function basename(path) {
      if (!path) return "";
      const parts = path.split("/");
      return parts[parts.length - 1] || path;
    }

    function formatSourceLabel(item) {
      const sourcePath = item.source_path || item.source_id || "";
      const shortName = basename(sourcePath);

      if (item.source_type === "upload") return `Upload: ${shortName}`;
      if (item.source_type === "git") return `Git: ${shortName}`;
      if (item.source_type === "local") return `Local: ${shortName}`;

      return shortName || item.source_id || "Unknown source";
    }

    function formatSourceMeta(item) {
      const parts = [];
      if (item.file_type) parts.push(item.file_type);
      if (item.source_type) parts.push(item.source_type);
      if (typeof item.chunk_count === "number") parts.push(`${item.chunk_count} chunks`);
      return parts.join(" | ");
    }

    function sortSourcesNewestFirst(items) {
      return [...items].sort((a, b) => {
        const aTime = new Date(a.last_ingested_at || 0).getTime();
        const bTime = new Date(b.last_ingested_at || 0).getTime();
        return bTime - aTime;
      });
    }

    function filterSources(items) {
      const search = document.getElementById("sourceSearch").value.trim().toLowerCase();
      const typeFilter = document.getElementById("sourceTypeFilter").value.trim();
      const showAll = document.getElementById("showAllSources").checked;

      let filtered = sortSourcesNewestFirst(items);

      if (typeFilter) {
        filtered = filtered.filter(item => (item.source_type || "") === typeFilter);
      }

      if (search) {
        filtered = filtered.filter(item => {
          const haystack = [
            item.source_path || "",
            item.source_id || "",
            item.file_type || "",
            item.source_type || "",
            formatSourceLabel(item)
          ].join(" ").toLowerCase();

          return haystack.includes(search);
        });
      }

      if (!showAll && !search) {
        filtered = filtered.slice(0, RECENT_SOURCE_LIMIT);
      }

      return filtered;
    }

    function renderSourceOptions() {
      const select = document.getElementById("sourceSelect");
      const summary = document.getElementById("sourceSummary");
      const currentValue = select.value;

      const filtered = filterSources(allSources);
      const options = ['<option value="">All sources</option>'];

      for (const item of filtered) {
        const label = formatSourceLabel(item);
        const meta = formatSourceMeta(item);
        const fullLabel = meta ? `${label} (${meta})` : label;

        options.push(`<option value="${escapeHtml(item.source_id)}">${escapeHtml(fullLabel)}</option>`);
      }

      select.innerHTML = options.join("");

      if (currentValue && filtered.some(item => item.source_id === currentValue)) {
        select.value = currentValue;
      }

      const total = allSources.length;
      const shown = filtered.length;
      const showAll = document.getElementById("showAllSources").checked;
      const search = document.getElementById("sourceSearch").value.trim();
      const typeFilter = document.getElementById("sourceTypeFilter").value.trim();

      let mode = "";
      if (search) mode = `Showing ${shown} matching source(s)`;
      else if (showAll) mode = `Showing all ${shown} source(s)`;
      else mode = `Showing ${shown} recent source(s) out of ${total}`;

      if (typeFilter) mode += ` | filtered by type: ${typeFilter}`;
      summary.textContent = total === 0 ? "No sources available yet." : mode;
    }

    function renderConversationList() {
      const list = document.getElementById("conversationList");

      if (!conversations.length) {
        list.innerHTML = "<div class='conversation-item'>No chats yet</div>";
        return;
      }

      list.innerHTML = conversations.map(item => {
        const active = item.conversation_id === currentConversationId ? "active" : "";
        return `
          <div class="conversation-item ${active}" onclick="openConversation('${escapeHtml(item.conversation_id)}')">
            <div class="conversation-title">${escapeHtml(item.title || "New Chat")}</div>
            <button class="delete-chat" onclick="deleteChat(event, '${escapeHtml(item.conversation_id)}')">×</button>
          </div>
        `;
      }).join("");
    }

    function renderMessages() {
      const container = document.getElementById("messages");

      if (!messages.length) {
        container.innerHTML = `
          <div class="empty-state">
            <h2>Start a new InfraRAG chat</h2>
            <p>Ask about uploaded books, DevOps docs, Terraform repos, incidents, or summaries. The backend decides the best pipeline automatically.</p>
          </div>
        `;
        return;
      }

      container.innerHTML = messages.map(message => {
        if (message.role === "user") {
          return `
            <div class="message user-message">
              <div class="avatar user">You</div>
              <div class="bubble">${escapeHtml(message.content)}</div>
            </div>
          `;
        }

        const meta = message.meta || {};
        const citations = Array.isArray(message.citations) ? message.citations : [];

        const metaHtml = meta.pipeline_label ? `
          <div class="meta-box">
            <div class="meta-grid">
              <div><strong>Pipeline:</strong> ${escapeHtml(meta.pipeline_label)}</div>
              <div><strong>Confidence:</strong> ${escapeHtml(meta.intent_confidence ?? "n/a")}</div>
              <div><strong>Router:</strong> ${escapeHtml(meta.router ?? "n/a")}</div>
              <div><strong>Latency:</strong> ${escapeHtml(meta.latency_ms ? `${meta.latency_ms} ms` : "n/a")}</div>
            </div>
            <div style="margin-top:6px;"><strong>Reason:</strong> ${escapeHtml(meta.intent_reason || "n/a")}</div>
          </div>
        ` : "";

        const citationsHtml = citations.length ? `
          <div class="citations">
            <strong>Citations</strong>
            ${citations.map(c => `
              <div class="citation-item">
                <div><strong>[${escapeHtml(c.citation_id ?? "")}]</strong> ${escapeHtml(c.source || "unknown")}</div>
                <div>Chunk: ${escapeHtml(c.chunk_index ?? "")} | Score: ${escapeHtml(c.score ?? "")}${c.page_number ? ` | Page: ${escapeHtml(c.page_number)}` : ""}</div>
              </div>
            `).join("")}
          </div>
        ` : `
          <div class="citations"><strong>Citations:</strong> none</div>
        `;

        return `
          <div class="message assistant-message">
            <div class="avatar assistant">AI</div>
            <div class="bubble">
              ${metaHtml}
              <div>${escapeHtml(message.content)}</div>
              ${citationsHtml}
            </div>
          </div>
        `;
      }).join("");

      container.scrollTop = container.scrollHeight;
    }

    function addLocalMessage(role, content, extra = {}) {
      messages.push({ role, content, ...extra });
      renderMessages();
    }

    function newChat() {
      currentConversationId = null;
      messages = [];
      renderMessages();
      renderConversationList();
      document.getElementById("question").focus();
    }

    async function loadConversations() {
      try {
        const res = await fetch("/api/conversations?limit=100");
        const data = await parseApiResponse(res);
        conversations = Array.isArray(data.conversations) ? data.conversations : [];
        renderConversationList();
      } catch (err) {
        console.error("Failed to load conversations:", err);
        conversations = [];
        renderConversationList();
      }
    }

    async function openConversation(conversationId) {
      currentConversationId = conversationId;
      messages = [];
      renderConversationList();

      try {
        const res = await fetch(`/api/conversations/${encodeURIComponent(conversationId)}/messages`);
        const data = await parseApiResponse(res);
        const loaded = Array.isArray(data.messages) ? data.messages : [];

        messages = loaded.map(item => {
          let citations = [];
          try {
            citations = item.sources_json ? JSON.parse(item.sources_json) : [];
          } catch {
            citations = [];
          }

          return {
            role: item.role,
            content: item.content,
            citations,
            meta: {
              pipeline_label: item.pipeline_used || "",
              intent_confidence: "",
              router: "",
              latency_ms: "",
              intent_reason: "",
            }
          };
        });

        renderMessages();
      } catch (err) {
        addLocalMessage("assistant", "Failed to load conversation: " + err.message);
      }
    }

    async function deleteChat(event, conversationId) {
      event.stopPropagation();

      if (!confirm("Delete this chat?")) return;

      try {
        const res = await fetch(`/api/conversations/${encodeURIComponent(conversationId)}`, {
          method: "DELETE"
        });
        await parseApiResponse(res);

        if (currentConversationId === conversationId) {
          currentConversationId = null;
          messages = [];
          renderMessages();
        }

        await loadConversations();
      } catch (err) {
        alert("Delete failed: " + err.message);
      }
    }

    function handleQuestionKey(event) {
      if (event.key === "Enter" && !event.shiftKey) {
        event.preventDefault();
        askQuestion();
      }
    }

    async function askQuestion() {
      const input = document.getElementById("question");
      const askButton = document.getElementById("askButton");
      const q = input.value.trim();

      const sourceId = document.getElementById("sourceSelect").value.trim();
      const pageStart = document.getElementById("pageStart").value.trim();
      const pageEnd = document.getElementById("pageEnd").value.trim();

      if (!q || isAsking) return;

      isAsking = true;
      askButton.disabled = true;
      askButton.textContent = "Thinking...";
      input.value = "";

      addLocalMessage("user", q);
      addLocalMessage("assistant", "Thinking...");

      try {
        const params = new URLSearchParams();
        params.set("q", q);

        if (currentConversationId) params.set("conversation_id", currentConversationId);
        if (sourceId) params.set("source_id", sourceId);
        if (pageStart) params.set("page_start", pageStart);
        if (pageEnd) params.set("page_end", pageEnd);

        const res = await fetch(`/api/ask?${params.toString()}`);
        const data = await parseApiResponse(res);

        currentConversationId = data.conversation_id || currentConversationId;

        messages.pop();
        addLocalMessage("assistant", data.answer || "", {
          citations: Array.isArray(data.citations) ? data.citations : [],
          meta: {
            pipeline_used: data.pipeline_used,
            pipeline_label: data.pipeline_label,
            intent_confidence: data.intent_confidence,
            intent_reason: data.intent_reason,
            router: data.router,
            latency_ms: data.latency_ms,
          }
        });

        await loadConversations();
      } catch (err) {
        messages.pop();
        addLocalMessage("assistant", "Request failed: " + err.message);
      } finally {
        isAsking = false;
        askButton.disabled = false;
        askButton.textContent = "Ask";
        input.focus();
      }
    }

    async function loadSources() {
      const summary = document.getElementById("sourceSummary");
      summary.textContent = "Loading sources...";

      try {
        const res = await fetch("/api/admin/sources?status=active&limit=1000");
        const data = await parseApiResponse(res);
        allSources = Array.isArray(data.sources) ? data.sources : [];
        renderSourceOptions();
      } catch (err) {
        allSources = [];
        renderSourceOptions();
        summary.textContent = "Failed to load sources.";
        console.error("Failed to load sources:", err);
      }
    }

    function toggleUploadPanel() {
      document.getElementById("uploadPanel").classList.toggle("open");
    }

    async function uploadFile() {
      const fileInput = document.getElementById("fileInput");
      const uploadStatus = document.getElementById("uploadStatus");

      if (!fileInput.files || fileInput.files.length === 0) {
        uploadStatus.textContent = "Please choose a file first.";
        return;
      }

      const file = fileInput.files[0];
      const formData = new FormData();
      formData.append("file", file);

      uploadStatus.textContent = `Uploading ${file.name}...`;

      try {
        const res = await fetch("/api/upload", {
          method: "POST",
          body: formData
        });
        await parseApiResponse(res);

        uploadStatus.textContent = `Upload complete: ${file.name}`;
        await loadSources();
      } catch (err) {
        uploadStatus.textContent = "Upload failed: " + err.message;
      }
    }

    async function uploadFolder() {
      const folderInput = document.getElementById("folderInput");
      const folderStatus = document.getElementById("folderStatus");

      if (!folderInput.files || folderInput.files.length === 0) {
        folderStatus.textContent = "Please choose a folder first.";
        return;
      }

      const files = Array.from(folderInput.files);
      const firstName = files[0].webkitRelativePath || files[0].name;
      const folderName = firstName.split("/")[0] || "folder_upload";

      const formData = new FormData();
      formData.append("folder_name", folderName);

      for (const file of files) {
        const relativeName = file.webkitRelativePath || file.name;
        formData.append("files", file, relativeName);
      }

      folderStatus.textContent = `Uploading folder ${folderName} with ${files.length} files...`;

      try {
        const res = await fetch("/api/upload-folder", {
          method: "POST",
          body: formData
        });
        await parseApiResponse(res);

        folderStatus.textContent = `Folder upload complete: ${folderName} (${files.length} files)`;
        await loadSources();
      } catch (err) {
        folderStatus.textContent = "Folder upload failed: " + err.message;
      }
    }

    loadSources();
    loadConversations();
  </script>
</body>
</html>
